<UserControl x:Class="IMRDesktopAssistant.Plugin.WashroomStatus.WashroomStatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="45">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Grid Grid.Column="0" ToolTip="1号：离线">
      <Ellipse x:Name="Outer1" Width="20" Height="20" Stroke="#737B86" StrokeThickness="2" />
      <Ellipse x:Name="Inner1" Width="7" Height="7" Fill="#737B86" />
    </Grid>
    <Grid Grid.Column="1" ToolTip="2号：离线">
      <Ellipse x:Name="Outer2" Width="20" Height="20" Stroke="#737B86" StrokeThickness="2" />
      <Ellipse x:Name="Inner2" Width="7" Height="7" Fill="#737B86" />
    </Grid>
    <Grid Grid.Column="2" ToolTip="3号：离线">
      <Ellipse x:Name="Outer3" Width="20" Height="20" Stroke="#737B86" StrokeThickness="2" />
      <Ellipse x:Name="Inner3" Width="7" Height="7" Fill="#737B86" />
    </Grid>
    <Grid Grid.Column="3" ToolTip="4号：离线">
      <Ellipse x:Name="Outer4" Width="20" Height="20" Stroke="#737B86" StrokeThickness="2" />
      <Ellipse x:Name="Inner4" Width="7" Height="7" Fill="#737B86" />
    </Grid>
  </Grid>
</UserControl>
