<Window x:Class="IMRDesktopAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IMR 设备助手"
        Width="292"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True">
  <Window.Resources>
    <Style x:Key="LabelText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#8F98A6" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="ValueText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#F4F6F8" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
  </Window.Resources>

  <Border Margin="12"
          Padding="17"
          CornerRadius="18"
          Background="#F21D2026"
          BorderBrush="#28FFFFFF"
          BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect BlurRadius="22" ShadowDepth="5" Opacity="0.35" Color="#000000" />
    </Border.Effect>

    <StackPanel>
      <StackPanel x:Name="PluginHost" Visibility="Collapsed" Margin="0,0,0,14" />

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="68" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="30" />
          <RowDefinition Height="30" />
          <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="计算机名" Style="{StaticResource LabelText}" />
        <TextBlock Grid.Row="1" Grid.Column="0" Text="IP 地址" Style="{StaticResource LabelText}" />
        <TextBlock Grid.Row="2" Grid.Column="0" Text="MAC 地址" Style="{StaticResource LabelText}" />

        <TextBlock x:Name="ComputerNameText" Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueText}" />
        <TextBlock x:Name="IpAddressText" Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueText}" />
        <TextBlock x:Name="MacAddressText" Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueText}" FontSize="12" />
      </Grid>
    </StackPanel>
  </Border>
</Window>
